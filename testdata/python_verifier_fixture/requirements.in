# Source manifest for the cross-implementation Python verifier deps. Edit
# this file, then run pip-compile to refresh requirements.txt:
#
#     python3 -m venv /tmp/pip-compile-venv
#     /tmp/pip-compile-venv/bin/pip install pip-tools
#     /tmp/pip-compile-venv/bin/pip-compile \
#         --generate-hashes \
#         --strip-extras \
#         --output-file=requirements.txt \
#         requirements.in
#
# Why two files: requirements.txt is the lockfile (==-pinned with hashes,
# unambiguous to OSV-Scanner and reproducible across machines); this .in
# file is the human-editable source of truth. OSV-Scanner has historically
# over-reported on >= range pins (treating "latest in range" as "all in
# range"), so loose pins in requirements.txt are forbidden — see
# CONTRIBUTING.md "Python dependencies".
#
# cryptography floor is 46.0.7: the 42.x-46.0 range is vulnerable to
# multiple advisories that all land by 46.0.7 (GHSA-r6ph-v2qm-q3c2,
# GHSA-p423-j2cm-9vmq, GHSA-m959-cc7f-wv43). Ed25519 verify is API-stable
# across 42.x-46.x.
cryptography>=47.0.0,<48.0.0
jcs>=0.2.1,<1.0.0
